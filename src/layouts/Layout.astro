---
import { DEFAULT_LOCALE } from "@/i18n/config";
import {
  translateFor,
  getLocaleInfo,
  getRelativeLocalePath,
} from "@/i18n/utils";
import { ClientRouter } from "astro:transitions";
import { SITE } from "@/config";
import "@/styles/global.css";

const t = translateFor(Astro.currentLocale);

const LOCALE = getLocaleInfo(Astro.currentLocale);

export interface Props {
  keywords?: string;
  tags?: string[];
  title?: string;
  author?: string;
  profile?: string;
  description?: string;
  ogImage?: string;
  canonicalURL?: string;
  pubDatetime?: Date;
  modDatetime?: Date | null;
  scrollSmooth?: boolean;
}

const {
  title = t("site.title"),
  author = SITE.author,
  // profile = SITE.profile,
  description = t("site.desc"),
  ogImage = SITE.ogImage
    ? `/${SITE.ogImage}`
    : `/og.png`,
  canonicalURL = new URL(Astro.url.pathname, Astro.url),
  pubDatetime,
  modDatetime,
  scrollSmooth = false,
  keywords,
  tags,
} = Astro.props;

const socialImageURL = new URL(ogImage, Astro.url);

const structuredData = pubDatetime ? {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: title,
  image: socialImageURL.href,
  datePublished: pubDatetime.toISOString(),
  ...(modDatetime && { dateModified: modDatetime.toISOString() }),
  author: {
    "@type": "Person",
    name: author,
  },
  publisher: {
    "@type": "Organization",
    name: SITE.author,
    logo: {
      "@type": "ImageObject",
      url: new URL("/og.png", Astro.site).href
    }
  },
  mainEntityOfPage: {
    "@type": "WebPage",
    "@id": canonicalURL.href
  }
} : {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: title,
  url: Astro.site?.href,
  description: description,
  author: {
    "@type": "Person",
    name: SITE.author,
  }
};
---

<!doctype html>
<html
  lang=`${Astro.currentLocale ?? DEFAULT_LOCALE}`
  class={`${scrollSmooth && "scroll-smooth"}`}
  dir={LOCALE.direction}
>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="canonical" href={canonicalURL} />
    <link
      rel="stylesheet"
      href="https://lib.arvancloud.ir/KaTeX/0.9.0-beta1/katex.min.css"
    />
    <meta name="generator" content={Astro.generator} />
    <script is:inline src="/toggle-theme.js"
    ></script>

    <!-- General Meta Tags -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <meta name="author" content={author} />
    <meta name="keywords" content={keywords || ""} />
    <link
      rel="sitemap" href="/sitemap-index.xml" />

    <!-- Open Graph / Facebook -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={socialImageURL} />
    <meta property="og:site_name" content={t("site.title")} />

    <!-- Article Published/Modified time -->
    {
      pubDatetime && (
        <meta
          property="article:published_time"
          content={pubDatetime.toISOString()}
        />
      )
    }
    {
      modDatetime && (
        <meta
          property="article:modified_time"
          content={modDatetime.toISOString()}
        />
      )
    }
    {
      pubDatetime && author && (
        <meta property="article:author" content={author} />
      )
    }
    {
      tags && tags.map(tag => (
        <meta property="article:tag" content={tag} />
      ))
    }


    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalURL} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={socialImageURL} />
    {SITE.twitterHandle && <meta name="twitter:site" content={SITE.twitterHandle} />}
    {SITE.twitterHandle && <meta name="twitter:creator" content={SITE.twitterHandle} />}

    <!-- Google JSON-LD Structured data -->
    <script
      type="application/ld+json"
      is:inline
      set:html={JSON.stringify(structuredData)}
    />

    <!-- Enable RSS feed auto-discovery  -->
    <!-- https://docs.astro.build/en/recipes/rss/#enabling-rss-feed-auto-discovery -->
    <link
      rel="alternate"
      type="application/rss+xml"
      title={t("site.title")}
      href={new URL(
        getRelativeLocalePath(Astro.currentLocale, "rss.xml"),
        Astro.site
      )}
    />

    <meta name="theme-color" content="" />

    <ClientRouter />

    <style
      is:inline
      set:html={`
      @font-face {
        font-family: "Vazir-Code";
        src: url("/assets/fonts/vazir-code/Vazir-Code.woff2") format("woff2");
        font-weight: 400;
        font-style: normal;
        font-display: swap;
      }
  `}
    ></style>
  </head>
  <body>
    <slot />
  </body>
</html>

<style>
  html,
  body {
    margin: 0;
    width: 100%;
    height: 100%;
  }
</style>
